{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A watch product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "featured": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["name", "category", "price", "image", "featured", "order"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "date": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        }
      },
      "required": ["customerName", "date", "total", "status", "paymentMethod", "items"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer who placed an order",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "totalOrders": { "type": "number" },
        "totalSpent": { "type": "number" },
        "lastOrderDate": { "type": "string" }
      },
      "required": ["name", "email", "phone", "totalOrders", "totalSpent", "lastOrderDate"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store products"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Store orders"
    },
    "/customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Store customers"
    }
  }
}
